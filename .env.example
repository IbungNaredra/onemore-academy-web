# Required for auth — use a NEW random value in `.env.local` (never commit real secrets).
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"

# Production: public site URL if NextAuth links fail.
# AUTH_URL=https://your-app.example.com

# PostgreSQL (Neon, local Docker, etc.)
DATABASE_URL="postgresql://onemore:onemore@localhost:5432/onemore_challenge?schema=public"

# Seed / first admin (must match a User row after `npm run db:seed` when DATABASE_URL is set)
ADMIN_EMAIL=admin.onemorechallenge@garena.com
ADMIN_PASSWORD=admin123

# Optional: password for prisma/seed load-test users (test.ugc.p01@garena.com … test.ugc.p20@garena.com). Default: test123456
# TEST_PARTICIPANT_PASSWORD=test123456

# Cron: Authorization: Bearer <secret> for GET /api/cron/batch-transitions
CRON_SECRET=
