# Required for auth — use a NEW random value in `.env.local` (never commit real secrets).
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"

# PostgreSQL connection string (Neon, Supabase, local Docker, etc.)
# With bundled docker-compose.yml: postgresql://onemore:onemore@localhost:5432/onemore_challenge?schema=public
# Next.js and Prisma both use this: Next loads `.env.local` automatically; Prisma loads it via `prisma.config.ts` (run commands from the project root).
DATABASE_URL="postgresql://onemore:onemore@localhost:5432/onemore_challenge?schema=public"
# Optional overrides (defaults in auth.ts + seed for local dev)
# When DATABASE_URL is set, sign-in uses User rows from the DB (after npm run db:seed).
ADMIN_EMAIL=admin@onemore.local
ADMIN_PASSWORD=admin123
JUDGE_EMAIL=judge@onemore.local
JUDGE_PASSWORD=judge123

# Public Google Form URL (Page 1 CTA)
NEXT_PUBLIC_GFORM_URL=https://forms.gle/replace-with-your-live-form-link

# Google Sheets API — admin “Pull from Google Sheet” on /admin/submissions
# See docs/GOOGLE-SHEETS.md. Share the spreadsheet with the service account client_email (Viewer is enough).
GOOGLE_SHEETS_SPREADSHEET_ID=
# Recommended: path to JSON key file (repo root). Do not paste multi-line JSON into .env — it will not parse.
GOOGLE_SERVICE_ACCOUNT_JSON_FILE=./google-service-account.json
# Alternative: entire JSON on ONE line (minified). Or run: npm run minify:google-key
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# A1 range (cols A–H). Google Forms usually use tab "Form Responses 1". Wrap in double quotes on Windows:
# GOOGLE_SHEETS_RANGE="'Form Responses 1'!A:H"
