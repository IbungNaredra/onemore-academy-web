generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// PRD v2.2 — participant voting platform
enum UserRole {
  PARTICIPANT
  FALLBACK_VOTER
  INTERNAL_TEAM
  ADMIN
}

enum ContentCategory {
  MINI_GAMES
  REAL_LIFE_PROMPT
}

enum BatchStatus {
  OPEN
  VOTING
  CONCLUDED
}

enum SubmissionStatus {
  ACTIVE
  DISQUALIFIED
}

enum GroupValidity {
  PENDING
  VALID
  UNDER_REVIEWED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  division     String
  role         UserRole @default(PARTICIPANT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submissions          Submission[]
  ratings              Rating[]
  groupAssignments     GroupVoterAssignment[]
  batchEligibilities   BatchVoterEligibility[]
}

model ProgramBatch {
  id                   String      @id @default(cuid())
  slug                 String      @unique
  label                String
  batchNumber          Int         @unique
  /// Transition times stored as UTC instants; cron compares using Asia/Shanghai wall clock.
  openAt               DateTime
  votingAt             DateTime
  concludedAt          DateTime
  leaderboardPublishAt DateTime?
  autoTransition       Boolean     @default(true)
  status               BatchStatus @default(OPEN)
  voterAssignmentDone  Boolean     @default(false)
  /// Wednesday Layer 2 voting window end (optional cap).
  layer2EndsAt         DateTime?
  winnersPublishedAt   DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  submissions Submission[]
  groups      ContentGroup[]
  eligibilities BatchVoterEligibility[]
  winners     PublishedWinner[]
}

model Submission {
  id                   String            @id @default(cuid())
  batchId              String
  batch                ProgramBatch      @relation(fields: [batchId], references: [id], onDelete: Cascade)
  userId               String
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category             ContentCategory
  contentUrl           String
  status               SubmissionStatus  @default(ACTIVE)
  disqualifyReason     String?
  normalizedScore      Float?
  totalRatingsReceived Int               @default(0)
  isFinalist           Boolean           @default(false)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  groupLinks GroupSubmission[]
  ratings    Rating[]
  winner     PublishedWinner?

  @@unique([batchId, contentUrl])
  @@index([batchId, category])
  @@index([userId])
}

model ContentGroup {
  id              String         @id @default(cuid())
  batchId         String
  batch           ProgramBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  category        ContentCategory
  /// 1 = Layer 1 (Tuesday peer voting); 2 = Layer 2 (Wednesday UNDER_REVIEWED).
  layer           Int
  validityStatus  GroupValidity  @default(PENDING)
  completionRate  Float?
  createdAt       DateTime       @default(now())

  submissions  GroupSubmission[]
  assignments  GroupVoterAssignment[]
  ratings      Rating[]

  @@index([batchId, category, layer])
}

model GroupSubmission {
  groupId      String
  submissionId String
  group        ContentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  submission   Submission   @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@id([groupId, submissionId])
}

model GroupVoterAssignment {
  id          String       @id @default(cuid())
  groupId     String
  group       ContentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  completed   Boolean      @default(false)
  completedAt DateTime?
  createdAt   DateTime     @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

/// One row per voter per submission (1–5). Unique per submission+voter across the program batch.
model Rating {
  id           String       @id @default(cuid())
  groupId      String
  group        ContentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  submissionId String
  submission   Submission   @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  voterId      String
  voter        User         @relation(fields: [voterId], references: [id], onDelete: Cascade)
  score        Int
  createdAt    DateTime     @default(now())

  @@unique([submissionId, voterId])
  @@index([groupId])
}

model BatchVoterEligibility {
  id            String       @id @default(cuid())
  batchId       String
  batch         ProgramBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  canVote       Boolean      @default(false)
  adminOverride Boolean      @default(false)

  @@unique([batchId, userId])
  @@index([userId])
}

model PublishedWinner {
  id             String       @id @default(cuid())
  batchId        String
  batch          ProgramBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  submissionId   String       @unique
  submission     Submission   @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  publishedScore Float?
  publishedAt    DateTime     @default(now())

  @@index([batchId])
}
